rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn()
        && (request.auth.token.role == role
          || request.auth.token.roles[role] == true);
    }

    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.admin == true || hasRole('admin'));
    }

    function isAgent() {
      return isSignedIn()
        && (request.auth.token.agent == true || hasRole('agent'));
    }

    function canManageContent() {
      return isAdmin() || isAgent();
    }

    function isPublished() {
      return resource.data.published == true;
    }

    match /releases/{docId} {
      allow read: if isPublished() || canManageContent();
      allow write: if canManageContent();
    }

    match /visuals/{docId} {
      allow read: if isPublished() || canManageContent();
      allow write: if canManageContent();
    }

    match /campaigns/{docId} {
      allow read: if isPublished() || canManageContent();
      allow write: if canManageContent();
    }

    match /events/{docId} {
      allow read: if isPublished() || canManageContent();
      allow write: if canManageContent();
    }

    match /products/{docId} {
      allow read: if isPublished() || canManageContent();
      allow write: if canManageContent();
    }

    match /site/{docId} {
      allow read: if true;
      allow write: if canManageContent();
    }

    match /users/{userId} {
      allow read, create, update: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow update, delete: if isAdmin();
    }

    match /newsletterSignups/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contactRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Mission Control ──────────────────────────────────────

    // Mission Control Users collection
    match /mission-control-users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admin users can read all profiles (for admin panel)
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.role == 'admin';

      // Only admin users can create/update profiles (invite system)
      allow create, update: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.role == 'admin';

      // Nobody can delete user profiles (deactivate instead)
      allow delete: if false;
    }

    // Notebook entries (future Firestore-backed notebook)
    match /mission-control-notebook/{entryId} {
      // All authenticated users with valid profiles can read
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.active == true;

      // Only admin and analyst roles can write
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.active == true &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.role in ['admin', 'analyst'];

      // Only admin can update/delete
      allow update, delete: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.role == 'admin';
    }

    // Operational data collections (future Firestore-backed data)
    match /mission-control-ops/{document=**} {
      // All authenticated active users can read
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.active == true;

      // Only admin can write operational data
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/mission-control-users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Default deny ────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
